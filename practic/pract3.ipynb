    "print(\"Исходный Series:\")\n",
    "print(s)\n",
    "\n",
    "filtered_s = s[s > 20]\n",
    "\n",
    "print(\"Элементы больше 20:\")\n",
    "print(filtered_s)"
   ]
  }
